# Bin or Deal — environment
# Copy this to .env.local and fill in what you have. Missing values degrade the
# corresponding adapter to "stub" status rather than breaking the app.

# ──────────────────────────────────────────────
# eBay Browse API (https://developer.ebay.com/api-docs/buy/browse/overview.html)
# OAuth client-credentials. Get credentials from the Production keyset:
#   https://developer.ebay.com/my/keys
# ──────────────────────────────────────────────
EBAY_APP_ID=
EBAY_CERT_ID=
# Optional: eBay Partner Network — monetization on outbound clicks
EBAY_EPN_CAMPAIGN_ID=

# ──────────────────────────────────────────────
# Cardmarket API (OAuth 1.0a, HMAC-SHA1)
# https://api.cardmarket.com/ws/documentation/API_2.0:Auth_OAuth
# ──────────────────────────────────────────────
CARDMARKET_APP_TOKEN=
CARDMARKET_APP_SECRET=
CARDMARKET_ACCESS_TOKEN=
CARDMARKET_ACCESS_TOKEN_SECRET=

# ──────────────────────────────────────────────
# Runtime knobs
# ──────────────────────────────────────────────
# Per-adapter per-user rate limit (seconds between requests)
ADAPTER_MIN_INTERVAL_SEC=2
# Global request timeout (ms)
ADAPTER_TIMEOUT_MS=8000

# Demo fallback: if a live adapter errors, fall back to mock data.
# Set to "false" for honest spike telemetry (errors surface as adapter status).
ADAPTER_DEMO_FALLBACK=true

# ──────────────────────────────────────────────
# PostHog (browser-side analytics)
# Project token (write-only, public). EU host by default.
# ──────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ──────────────────────────────────────────────
# Postgres (local Docker or Neon)
# Local:  docker compose up -d  →  postgres://binordeal:binordeal@localhost:5433/binordeal
# Neon:   postgresql://user:pass@ep-xxx.eu-central-1.neon.tech/binordeal?sslmode=require
# ──────────────────────────────────────────────
DATABASE_URL=
